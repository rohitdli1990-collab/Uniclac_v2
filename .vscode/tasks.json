{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile Java",
            "type": "shell",
            "command": "javac",
            "args": [
                "-d",
                "bin",
                "Main.java",
                "calculation-classes/Basic_clac.java"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$javac"]
        },
        {
            "label": "Run Calculator",
            "type": "shell",
            "command": "java",
            "args": [
                "-cp",
                "bin",
                "Main"
            ],
            "dependsOn": ["Compile Java"],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
